{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=authdb;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Issuer": "http://localhost:5085/",
    "Authority": "http://localhost:5085/",
    "Audience": "eztrade-platform",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "ElasticLogging": {
    "Enabled": true,
    "EnableConsoleSink": true,
    "LogDirectory": "logs",
    "MinimumLevel": "Information",
    "RetainedFileCountLimit": 14
  },
  "Nacos": {
    "Enabled": true,
    "LoadConfiguration": false,
    "RegisterService": false,
    "ServerAddress": "http://localhost:8848",
    "NamespaceId": "public",
    "Group": "EZTRADE_PLATFORM",
    "ClusterName": "DEFAULT",
    "ServiceName": "auth-center",
    "ConfigDataId": "auth-center.json",
    "InstancePort": 5085,
    "Metadata": {
      "protocol": "http",
      "role": "identity"
    }
  },
  "Seed": {
    "Admin": {
      "UserName": "admin",
      "Email": "admin@eztrade.local",
      "Password": "Admin123!"
    },
    "Clients": [
      {
        "ClientId": "eztrade.cli",
        "DisplayName": "EzTrade CLI",
        "ClientType": "public",
        "GrantTypes": [
          "password",
          "refresh_token"
        ],
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "roles",
          "offline_access",
          "orders",
          "inventory",
          "payments",
          "identity"
        ],
        "GrantedPermissions": [
          "orders.read",
          "orders.write",
          "inventory.read",
          "inventory.write",
          "payments.read",
          "payments.write",
          "identity.manage"
        ]
      },
      {
        "ClientId": "eztrade.service",
        "DisplayName": "EzTrade Service Client",
        "ClientType": "confidential",
        "ClientSecret": "EzTrade.Service.Secret!ChangeMe",
        "GrantTypes": [
          "client_credentials"
        ],
        "AllowedScopes": [
          "orders",
          "inventory",
          "payments",
          "identity"
        ],
        "GrantedPermissions": [
          "orders.read",
          "orders.write",
          "inventory.read",
          "inventory.write",
          "payments.read",
          "payments.write",
          "identity.manage"
        ]
      }
    ]
  }
}