{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=inventorydb;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Issuer": "http://localhost:5085/",
    "Authority": "http://localhost:5085/",
    "Audience": "eztrade-platform",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "ElasticLogging": {
    "Enabled": true,
    "EnableConsoleSink": true,
    "LogDirectory": "logs",
    "MinimumLevel": "Information",
    "RetainedFileCountLimit": 14
  },
  "Nacos": {
    "Enabled": true,
    "LoadConfiguration": false,
    "RegisterService": false,
    "ServerAddress": "http://localhost:8848",
    "NamespaceId": "public",
    "Group": "EZTRADE_PLATFORM",
    "ClusterName": "DEFAULT",
    "ServiceName": "inventory-api",
    "ConfigDataId": "inventory-api.json",
    "InstancePort": 5270,
    "Metadata": {
      "protocol": "http",
      "boundedContext": "inventory"
    }
  }
}