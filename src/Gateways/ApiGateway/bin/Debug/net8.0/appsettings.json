{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Issuer": "http://localhost:5085/",
    "Authority": "http://localhost:5085/",
    "Audience": "eztrade-platform",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "ElasticLogging": {
    "Enabled": true,
    "EnableConsoleSink": true,
    "LogDirectory": "logs",
    "MinimumLevel": "Information",
    "RetainedFileCountLimit": 14
  },
  "Nacos": {
    "Enabled": true,
    "LoadConfiguration": false,
    "RegisterService": false,
    "ServerAddress": "http://localhost:8848",
    "NamespaceId": "public",
    "Group": "EZTRADE_PLATFORM",
    "ClusterName": "DEFAULT",
    "ServiceName": "api-gateway",
    "ConfigDataId": "api-gateway.json",
    "InstancePort": 5096,
    "Metadata": {
      "protocol": "http",
      "role": "gateway"
    }
  },
  "Services": {
    "AuthCenter": "http://localhost:5085",
    "Orders": "http://localhost:5239",
    "Inventory": "http://localhost:5270",
    "Payments": "http://localhost:5066",
    "Bff": "http://localhost:5097"
  }
}